# Zomato AI Recommendation System — Environment Variables
# Copy this file to .env and fill in the values.

# Groq API key (required)
GROQ_API_KEY=

# Groq model name (optional, defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Maximum candidates sent to Groq per request (optional, defaults to 30)
# MAX_CANDIDATES=30

# Local dataset cache path (optional, defaults to data/restaurants.parquet)
# CACHE_PATH=data/restaurants.parquet
